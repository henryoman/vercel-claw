{
  "name": "@vercel-claw/cli",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "bin",
    "dist",
    "template"
  ],
  "bin": {
    "vercel-claw": "./bin/vercel-claw",
    "create-vercel-claw": "./bin/create-vercel-claw"
  },
  "scripts": {
    "dev": "bun run ./src/index.ts",
    "build": "bun build ./src/index.ts --outfile ./dist/index.js --target bun",
    "build:tools": "bun run ./scripts/build-tool-registry.ts",
    "check": "bunx tsc --noEmit",
    "sync:template": "bun run ./scripts/sync-template.ts",
    "prepack": "bun run sync:template"
  },
  "dependencies": {
    "convex": "^1.34.1",
    "fflate": "^0.8.2",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/semver": "^7.7.1",
    "@vercel-claw/core": "workspace:*"
  },
  "private": true,
  "peerDependencies": {
    "typescript": "^6.0.2"
  }
}
