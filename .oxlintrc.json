{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "react", "nextjs", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "settings": {
    "next": {
      "rootDir": "apps/vercel-claw/"
    }
  },
  "ignorePatterns": [
    ".next/**",
    "dist/**",
    ".dist/**",
    "coverage/**",
    "apps/vercel-claw/next-env.d.ts",
    "apps/vercel-claw/convex/_generated/**"
  ]
}
