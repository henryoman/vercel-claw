{
  "name": "vercel-claw",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/vercel-claw",
    "apps/agent-studio/cli",
    "apps/agent-studio/core"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@vercel-claw/cli -- dev",
    "dev:app": "turbo run dev --filter=@vercel-claw/app",
    "cli": "turbo run dev --filter=@vercel-claw/cli",
    "studio": "bun run ./scripts/studio.ts",
    "convex:once": "set -a && . ./.env.local && set +a && cd apps/vercel-claw && bunx convex dev --once --tail-logs disable",
    "lint": "oxlint .",
    "build:tools": "turbo run build:tools --filter=@vercel-claw/cli",
    "build": "turbo run build",
    "check": "turbo run check",
    "typecheck": "bun run check",
    "test": "bun test",
    "ci": "bun run convex:once && bun run lint && bun run typecheck && bun run test && bun run build && bun run build:tools",
    "update-all": "bun run ./scripts/update-all.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "oxlint": "^1.58.0",
    "turbo": "^2.9.4",
    "typescript": "^6.0.2"
  }
}
